<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Singularidi.Controls"
        xmlns:vm="clr-namespace:Singularidi.ViewModels"
        x:Class="Singularidi.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Singularidi — MIDI Visualizer"
        Width="1280" Height="720"
        MinWidth="640" MinHeight="400"
        Background="#0d0d0d">

  <Window.Styles>
    <!-- Style for dynamically-generated child MenuItems within .dynamic parents -->
    <Style Selector="MenuItem.dynamic MenuItem"
           x:DataType="vm:MenuItemViewModel">
      <Setter Property="Header" Value="{Binding Header}"/>
      <Setter Property="Command" Value="{Binding Command}"/>
      <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
    </Style>
  </Window.Styles>

  <DockPanel>

    <!-- Menu bar -->
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="Open MIDI File…" Command="{Binding OpenMidiFileCommand}" InputGesture="Ctrl+O"/>
        <Separator/>
        <MenuItem Header="Export to MP4…" Command="{Binding ExportToMp4Command}"/>
        <Separator/>
        <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="Highlight Active Notes"
                  ToggleType="CheckBox" IsChecked="{Binding HighlightActiveNotes}"/>
        <Separator/>
        <MenuItem Header="Visualization" Classes="dynamic" ItemsSource="{Binding VisualizationMenuItems}"/>
        <Separator/>
        <MenuItem Header="Theme" Classes="dynamic" ItemsSource="{Binding ThemeMenuItems}"/>
      </MenuItem>
      <MenuItem Header="_Audio">
        <MenuItem Header="Output Mode">
          <MenuItem Header="SoundFont Synthesis" Command="{Binding SetSoundFontModeCommand}"/>
          <MenuItem Header="MIDI Device" Command="{Binding SetMidiDeviceModeCommand}"/>
        </MenuItem>
        <Separator/>
        <MenuItem Header="Select SoundFont…" Command="{Binding SelectSoundFontCommand}"/>
        <MenuItem Header="Save SoundFont as Default" Command="{Binding SaveSoundFontDefaultCommand}"/>
        <Separator/>
        <MenuItem Header="MIDI Devices" Classes="dynamic" ItemsSource="{Binding MidiDeviceMenuItems}"/>
      </MenuItem>
    </Menu>

    <!-- Toolbar -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6"
                Background="#1a1a1a" Margin="0" Height="36">
      <Button Content="Open MIDI" Command="{Binding OpenMidiFileCommand}" Margin="6,4,0,4" Padding="8,2"/>
      <Button Content="▶ Play"  Command="{Binding PlayCommand}"
              IsEnabled="{Binding CanPlay}" Margin="0,4,0,4" Padding="8,2"/>
      <Button Content="⏸ Pause" Command="{Binding PauseCommand}"
              IsEnabled="{Binding CanPause}" Margin="0,4,0,4" Padding="8,2"/>
      <Button Content="⏹ Stop"  Command="{Binding StopCommand}"
              IsEnabled="{Binding CanStop}"  Margin="0,4,0,4" Padding="8,2"/>
      <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                 Foreground="#cccccc" Margin="10,0,0,0" FontSize="12"/>
    </StackPanel>

    <!-- Visualizer fills remaining space -->
    <controls:NoteVisualizerControl
        VisualTheme="{Binding CurrentTheme}"
        HighlightActiveNotes="{Binding HighlightActiveNotes}"
        Engine="{Binding Engine}"
        VisualizationEngine="{Binding CurrentVisualization}"/>

  </DockPanel>
</Window>
